{
  "name": "RetroMultiCiv",
  "tree": {
    "$className": "DataModel",
    "Workspace": {
      "$properties": { "StreamingEnabled": false }
    },
    "ReplicatedStorage": {
      "Shared": {
        "$className": "Folder",
        "$path": { "optional": "../luau" }
      },
      "GameData": {
        "$path": "data/generated"
      }
    },
    "ServerScriptService": {
      "RetroMultiCiv": {
        "$path": "src/server"
      }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "RetroMultiCivClient": {
          "$path": "src/client"
        }
      }
    }
  }
}
